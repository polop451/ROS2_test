<?xml version="1.0"?>
<robot name="simple_manipulator">

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.2" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
    <origin xyz="0 0 0.25" rpy="0 0 0"/> <mass value="1.0"/> <inertia ixx="0.0213" ixy="0.0" ixz="0.0" iyy="0.0213" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.5"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.5"/>
      </geometry>
    </collision>
    <inertial>
    <origin xyz="0 0 0.25" rpy="0 0 0"/> <mass value="1.0"/> <inertia ixx="0.0213" ixy="0.0" ixz="0.0" iyy="0.0213" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.4"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.4"/>
      </geometry>
    </collision>
    <inertial>
    <origin xyz="0 0 0.25" rpy="0 0 0"/> <mass value="1.0"/> <inertia ixx="0.0213" ixy="0.0" ixz="0.0" iyy="0.0213" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="link_3"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <geometry>
        <box size="0.1 0.04 0.04"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.04 0.04"/>
      </geometry>
    </collision>
    <inertial>
    <origin xyz="0 0 0.25" rpy="0 0 0"/> <mass value="1.0"/> <inertia ixx="0.0213" ixy="0.0" ixz="0.0" iyy="0.0213" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_gripper_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_gripper_jaw"/>
    <origin xyz="-0.04 0 0.02" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.03" effort="5.0" velocity="0.5"/>
  </joint>

  <link name="left_gripper_jaw">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.02 0.06"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.02 0.06"/>
      </geometry>
    </collision>
    <inertial>
    <origin xyz="0 0 0.25" rpy="0 0 0"/> <mass value="1.0"/> <inertia ixx="0.0213" ixy="0.0" ixz="0.0" iyy="0.0213" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

</robot>